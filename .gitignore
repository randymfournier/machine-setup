# Repo-wide ignore — keeps secrets out of git no matter where they're put.

# Never commit private keys
*.pem
*.key
*.pfx
*.p12
id_rsa
id_ed25519
id_ecdsa

# Never commit env files
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Local-only customizations (e.g., a real .gitconfig with your actual email)
*.local

# Generated installer/bootstrap logs
logs/
*.log

# Generated setup state
state/*.json
!state/.gitkeep

# Local exported driver packages can be large and machine-specific.
drivers/exported-*/
drivers/exported-selected-*/
assets/drivers/exported-*/
assets/drivers/exported-selected-*/

# Optional offline recovery assets; keep them on USB/local disk, not GitHub.
installers/*.exe
installers/*.msixbundle
assets/installers/*.exe
assets/installers/*.msixbundle
assets/office/setup.exe
assets/office/Office/
assets/office/postInstall.local.ps1

# Local USB staging/export output
usb-staging/
*.iso
*.wim
*.esd
